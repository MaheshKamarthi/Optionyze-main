<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/app-shell.css" />
    <link rel="stylesheet" href="/css/account-menu.css" />
    <link rel="stylesheet" href="/css/rolling-options-strangle.css" />
</head>
<body class="app-page" data-rolling-api-base="/api/rollingoptions-strangle">
    <div class="app-layout rolling-demo-layout">
        <%- include('partials/app-header', { currentAccount }) %>

        <section class="rolling-demo-hero">
            <div class="app-panel rolling-demo-card">
                <h1 class="rolling-demo-title">Rolling Option Strangle Demo</h1>
            </div>
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-summary">
                    <div class="app-stat rolling-demo-stat">
                        <div class="rolling-demo-stat-label">Engine Status</div>
                        <div class="rolling-demo-stat-value" id="rollingDemoEngineStatus">Idle</div>
                    </div>
                    <div class="app-stat rolling-demo-stat">
                        <div class="rolling-demo-stat-label">Open Positions</div>
                        <div class="rolling-demo-stat-value" id="rollingDemoOpenCount">0</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="rolling-demo-section">
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <div class="rolling-demo-inline">
                        <span class="rolling-demo-manual-title">Manual Trader 1</span>
                    </div>
                    <div class="rolling-demo-card-tools">
                        <button class="rolling-demo-btn warn" type="button" id="btnRollingDemoAutoTrader">Auto Trader - OFF</button>
                    </div>
                </div>

                <div class="rolling-demo-grid futures">
                    <div class="rolling-demo-field">
                        <label for="ddlCoveredCallSymbol">Symbols List</label>
                        <select id="ddlCoveredCallSymbol">
                            <option value="BTC" selected>BTCUSD</option>
                            <option value="ETH">ETHUSD</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtCoveredCallLotSize">Lot Size</label>
                        <input type="text" id="txtCoveredCallLotSize" value="0.001" readonly />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtManualFutQty">Qty</label>
                        <input type="number" min="1" step="1" id="txtManualFutQty" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlManualFutOrderType">Order Type</label>
                        <select id="ddlManualFutOrderType">
                            <option value="limit_order">Limit Order</option>
                            <option value="market_order" selected>Market Order</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlManualFutAction">Action</label>
                        <select id="ddlManualFutAction">
                            <option value="SELL" selected>Sell</option>
                            <option value="BUY">Buy</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoFuturesEnabled">FUT Enabled</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoFuturesEnabled">
                                <input type="checkbox" id="chkRollingDemoFuturesEnabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoPlaceFuture">Place FUT</button>
                    </div>
                </div>

                <div class="rolling-demo-grid options rolling-demo-section">
                    <div class="rolling-demo-field">
                        <label for="ddlActionCoveredCall1">Action</label>
                        <select id="ddlActionCoveredCall1">
                            <option value="none">None</option>
                            <option value="buy">Buy</option>
                            <option value="sell" selected>Sell</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlLegSideCoveredCall1">Legs</label>
                        <select id="ddlLegSideCoveredCall1">
                            <option value="both">Both</option>
                            <option value="ce" selected>CE</option>
                            <option value="pe">PE</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlExpiryModeCoveredCall1">Expiry Type</label>
                        <select id="ddlExpiryModeCoveredCall1">
                            <option value="1" selected>DAILY T+1</option>
                            <option value="2">DAILY T+2</option>
                            <option value="4">WEEKLY</option>
                            <option value="5">BI-WEEKLY</option>
                            <option value="6">MONTHLY</option>
                            <option value="7">BI-MONTHLY</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtExpiryCoveredCall1">Select Expiry</label>
                        <input type="date" id="txtExpiryCoveredCall1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtManualOptQtyCoveredCall1">Qty</label>
                        <input type="number" min="0" value="1" id="txtManualOptQtyCoveredCall1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkReLegCoveredCall1">Re Enter</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkReLegCoveredCall1">
                                <input type="checkbox" id="chkReLegCoveredCall1" />
                            </label>
                        </div>
                    </div>
                </div>

                <div class="rolling-demo-subgrid">
                    <div class="rolling-demo-field">
                        <label for="txtGreenOptQtyCoveredCall">Green Opt Qty</label>
                        <input type="number" min="0" step="1" id="txtGreenOptQtyCoveredCall" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReGreenDCoveredCall">Re Green D</label>
                        <input type="number" min="0.0" max="2.0" step="0.01" id="txtReGreenDCoveredCall" value="0.53" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReGreenTPCoveredCall">Green TP %</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtReGreenTPCoveredCall" value="15" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailGreenTp1Enabled">Green Renko Close 1</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailGreenTp1Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailGreenTp1Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReGreenSLCoveredCall">Green SL %</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtReGreenSLCoveredCall" value="85" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailGreenSl1Enabled">Trail Green SL 1</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailGreenSl1Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailGreenSl1Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoUpdateGreenRules">Update Green</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn buy" type="button" id="btnRollingDemoOpenOption">OPEN OPTION</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRedOptQtyCoveredCall">Red Opt Qty</label>
                        <input type="number" min="0" step="1" id="txtRedOptQtyCoveredCall" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReDeltaCoveredCall1">Re Red D</label>
                        <input type="number" min="0.0" max="2.0" step="0.01" id="txtReDeltaCoveredCall1" value="0.53" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtDeltaTPCoveredCall1">Red TP %</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtDeltaTPCoveredCall1" value="15" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailRedTp1Enabled">Red Renko Close 1</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailRedTp1Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailRedTp1Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtDeltaSLCoveredCall1">Red SL %</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtDeltaSLCoveredCall1" value="85" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailRedSl1Enabled">Trail Red SL 1</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailRedSl1Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailRedSl1Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoUpdateRedRules">Update Red</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <div class="rolling-demo-inline">
                            <button class="rolling-demo-btn warn" type="button" id="btnRollingDemoExitOption">EXIT OPTION</button>
                            <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoExecStrategy">Exec Strategy</button>
                        </div>
                    </div>
                    <div class="rolling-demo-field rolling-demo-field-new-row">
                        <label for="ddlActionCoveredCall2">Action 2</label>
                        <select id="ddlActionCoveredCall2">
                            <option value="none" selected>None</option>
                            <option value="buy">Buy</option>
                            <option value="sell">Sell</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlLegSideCoveredCall2">Legs 2</label>
                        <select id="ddlLegSideCoveredCall2">
                            <option value="both">Both</option>
                            <option value="ce">CE</option>
                            <option value="pe" selected>PE</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlExpiryModeCoveredCall2">Expiry Type 2</label>
                        <select id="ddlExpiryModeCoveredCall2">
                            <option value="1" selected>DAILY T+1</option>
                            <option value="2">DAILY T+2</option>
                            <option value="4">WEEKLY</option>
                            <option value="5">BI-WEEKLY</option>
                            <option value="6">MONTHLY</option>
                            <option value="7">BI-MONTHLY</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtExpiryCoveredCall2">Select Expiry 2</label>
                        <input type="date" id="txtExpiryCoveredCall2" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtManualOptQtyCoveredCall2">Qty 2</label>
                        <input type="number" min="0" value="1" id="txtManualOptQtyCoveredCall2" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkReLegCoveredCall2">Re Enter 2</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkReLegCoveredCall2">
                                <input type="checkbox" id="chkReLegCoveredCall2" />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field rolling-demo-field-new-row">
                        <label for="txtGreenOptQtyCoveredCall2">Green Opt Qty 2</label>
                        <input type="number" min="0" step="1" id="txtGreenOptQtyCoveredCall2" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReGreenDCoveredCall2">Re Green D 2</label>
                        <input type="number" min="0.0" max="2.0" step="0.01" id="txtReGreenDCoveredCall2" value="0.53" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReGreenTPCoveredCall2">Green TP % 2</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtReGreenTPCoveredCall2" value="15" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailGreenTp2Enabled">Green Renko Close 2</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailGreenTp2Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailGreenTp2Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReGreenSLCoveredCall2">Green SL % 2</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtReGreenSLCoveredCall2" value="85" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailGreenSl2Enabled">Trail Green SL 2</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailGreenSl2Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailGreenSl2Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoUpdateGreenRules2">Update Green</button>
                    </div>
                    <div class="rolling-demo-field rolling-demo-field-new-row">
                        <label for="txtRedOptQtyCoveredCall2">Red Opt Qty 2</label>
                        <input type="number" min="0" step="1" id="txtRedOptQtyCoveredCall2" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtReRedDCoveredCall2">Re Red D 2</label>
                        <input type="number" min="0.0" max="2.0" step="0.01" id="txtReRedDCoveredCall2" value="0.53" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRedTPCoveredCall2">Red TP % 2</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtRedTPCoveredCall2" value="15" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailRedTp2Enabled">Red Renko Close 2</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailRedTp2Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailRedTp2Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRedSLCoveredCall2">Red SL % 2</label>
                        <input type="number" min="0" max="100" step="0.1" id="txtRedSLCoveredCall2" value="85" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoTrailRedSl2Enabled">Trail Red SL 2</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoTrailRedSl2Enabled">
                                <input type="checkbox" id="chkRollingDemoTrailRedSl2Enabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoUpdateRedRules2">Update Red</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <div class="rolling-demo-inline">
                            <button class="rolling-demo-btn buy" type="button" id="btnRollingDemoOpenOption2">OPEN OPTION 2</button>
                            <button class="rolling-demo-btn warn" type="button" id="btnRollingDemoExitOption2">EXIT OPTION 2</button>
                        </div>
                    </div>
                </div>

                <div class="rolling-demo-grid metrics rolling-demo-section">
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">1 x / Lot</div>
                        <div class="rolling-demo-metric-value" id="rollingDemoOneLotValue">-</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Total Margin</div>
                        <div class="rolling-demo-metric-value" id="rollingDemoTotalMarginValue">-</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Blocked Margin</div>
                        <div class="rolling-demo-metric-value" id="rollingDemoBlockedMarginValue">-</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Available Balance</div>
                        <input
                            class="rolling-demo-metric-input"
                            type="number"
                            min="0"
                            max="999999999"
                            step="0.01"
                            id="txtRollingDemoDemoBalance"
                            value="10000"
                        />
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Health</div>
                        <div class="rolling-demo-metric-value" id="rollingDemoHealthValue">-</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Open PnL</div>
                        <div class="rolling-demo-metric-value" id="rollingDemoOpenPnlValue">0.000</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Target Open PnL</div>
                        <input
                            class="rolling-demo-metric-input"
                            type="number"
                            min="-999999999"
                            max="999999999"
                            step="0.001"
                            id="txtRollingDemoTargetOpenPnl"
                            value="0"
                        />
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Closed PnL</div>
                        <input
                            class="rolling-demo-metric-input"
                            type="number"
                            min="-999999999"
                            max="999999999"
                            step="0.001"
                            id="txtRollingDemoOptionsPnl"
                            readonly
                            value="0.000"
                        />
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Total PnL</div>
                        <input
                            class="rolling-demo-metric-input"
                            type="number"
                            min="-999999999"
                            max="999999999"
                            step="0.001"
                            id="txtRollingDemoTotalPnl"
                            readonly
                            value="0.000"
                        />
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Charges</div>
                        <input
                            class="rolling-demo-metric-input"
                            type="number"
                            min="0"
                            max="999999999"
                            step="0.001"
                            id="txtRollingDemoTotalCharges"
                            readonly
                            value="0.000"
                        />
                    </div>
                </div>
            </div>
        </section>

        <section class="rolling-demo-section">
            <div class="app-panel rolling-demo-card rolling-demo-positive-pnl-settings">
                <div class="rolling-demo-card-head">
                    <h2>Positive PnL Option Leg</h2>
                </div>
                <div class="rolling-demo-grid options">
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoPositivePnlSupportEnabled">Enable</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoPositivePnlSupportEnabled">
                                <input type="checkbox" id="chkRollingDemoPositivePnlSupportEnabled" checked />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlRollingDemoPositivePnlSupportAction">Support Action</label>
                        <select id="ddlRollingDemoPositivePnlSupportAction">
                            <option value="buy" selected>Buy</option>
                            <option value="sell">Sell</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingDemoPositivePnlSupportQty">Support Qty</label>
                        <input type="number" min="1" step="1" id="txtRollingDemoPositivePnlSupportQty" value="10" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingDemoPositivePnlMaxLegs">Max Legs</label>
                        <input type="number" min="1" step="1" id="txtRollingDemoPositivePnlMaxLegs" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingDemoPositivePnlTriggerAmount">Trigger Amount</label>
                        <input type="number" max="0" step="0.01" id="txtRollingDemoPositivePnlTriggerAmount" value="0" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlRollingDemoPositivePnlExpiryMode">Expiry Type</label>
                        <select id="ddlRollingDemoPositivePnlExpiryMode">
                            <option value="source">Source Leg</option>
                            <option value="1" selected>DAILY T+1</option>
                            <option value="2">DAILY T+2</option>
                            <option value="4">WEEKLY</option>
                            <option value="5">BI-WEEKLY</option>
                            <option value="6">MONTHLY</option>
                            <option value="7">BI-MONTHLY</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingDemoPositivePnlTargetDelta">Target Delta</label>
                        <input type="number" min="0" max="2" step="0.01" id="txtRollingDemoPositivePnlTargetDelta" value="0.53" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingDemoPositivePnlTp">TP %</label>
                        <input type="number" min="0" max="100" step="0.01" id="txtRollingDemoPositivePnlTp" value="15" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingDemoPositivePnlSl">SL %</label>
                        <input type="number" min="0" max="100" step="0.01" id="txtRollingDemoPositivePnlSl" value="85" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingDemoPositivePnlAdverseRenkoClose">Adverse Renko Close</label>
                        <div class="rolling-demo-check-wrap">
                            <label class="rolling-demo-check" for="chkRollingDemoPositivePnlAdverseRenkoClose">
                                <input type="checkbox" id="chkRollingDemoPositivePnlAdverseRenkoClose" />
                            </label>
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <div class="rolling-demo-inline">
                            <button class="rolling-demo-btn buy" type="button" id="btnRollingDemoOpenPositivePnl">OPEN</button>
                            <button class="rolling-demo-btn primary" type="button" id="btnRollingDemoUpdatePositivePnl">Update</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="rolling-demo-section">
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <h2>Open Positions</h2>
                    <div class="rolling-demo-card-tools">
                        <label class="rolling-demo-check" for="chkRollingDemoCloseAllLegsOnAnyClose" title="When enabled, closing a negative option leg will close all open legs">
                            <input type="checkbox" id="chkRollingDemoCloseAllLegsOnAnyClose" />
                            Close all on negative options
                        </label>
                        <label class="rolling-demo-check" for="chkRollingDemoSkipRenkoEntryNoOpenOptions" title="Skip renko option entry when there are no open option legs">
                            <input type="checkbox" id="chkRollingDemoSkipRenkoEntryNoOpenOptions" />
                            Skip entry (0 open opts)
                        </label>
                        <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingDemoRefreshOpenPositions" title="Refresh open positions" aria-label="Refresh open positions">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                                <path d="M21 3v6h-6" />
                            </svg>
                        </button>
                        <button class="rolling-demo-icon-btn sell" type="button" id="btnRollingDemoKillSwitch" title="Kill switch to close all open paper legs" aria-label="Kill switch to close all open paper legs">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2v10" />
                                <path d="M6.2 6.2a8 8 0 1 0 11.3 0" />
                            </svg>
                        </button>
                        <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingDemoClearOpenPositions" title="Clear all open paper positions" aria-label="Clear all open paper positions">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3 6h18" />
                                <path d="M8 6V4h8v2" />
                                <path d="M19 6l-1 14H6L5 6" />
                                <path d="M10 11v6" />
                                <path d="M14 11v6" />
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="rolling-demo-table-wrap">
                    <table class="rolling-demo-table rolling-demo-table-open">
                        <thead>
                            <tr>
                                <th>Delta</th>
                                <th>C Delta</th>
                                <th>TP Delta</th>
                                <th>SL Delta</th>
                                <th>Symbol</th>
                                <th>Tr Type</th>
                                <th>Lot Sz</th>
                                <th>Qty</th>
                                <th>Buy Price</th>
                                <th>Sell Price</th>
                                <th>LTP</th>
                                <th>Charges</th>
                                <th>P &amp; L</th>
                                <th>Start DT</th>
                                <th>End DT</th>
                                <th>Status</th>
                                <th>Link</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="rollingDemoOpenPositionsBody">
                            <tr>
                                <td colspan="18" class="rolling-demo-empty">No open paper positions yet. Server-side wiring will populate this table later.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="rolling-demo-payoff rolling-strangle-demo-payoff" id="rollingDemoOpenPayoffGraph">
                    <div class="rolling-demo-payoff-empty">Payoff graph appears when open legs are available.</div>
                </div>
            </div>
        </section>

        <section class="rolling-demo-section">
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <h2>Closed Positions</h2>
                    <div class="rolling-demo-card-tools">
                        <div class="rolling-demo-filters">
                            <div class="rolling-demo-field">
                                <input type="datetime-local" id="txtClsFromDate" title="Filter closed positions from this date and time" aria-label="Filter closed positions from this date and time" />
                            </div>
                            <div class="rolling-demo-field">
                                <input type="datetime-local" id="txtClsToDate" title="Filter closed positions up to this date and time" aria-label="Filter closed positions up to this date and time" />
                            </div>
                            <div class="rolling-demo-field">
                                <div class="rolling-demo-check-wrap">
                                    <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingDemoClearClosedFilters" title="Clear closed-position date filters" aria-label="Clear closed-position date filters">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M18 6 6 18" />
                                            <path d="m6 6 12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <div class="rolling-demo-field">
                                <div class="rolling-demo-check-wrap">
                                    <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingDemoClearClosedPositions" title="Delete all closed paper positions" aria-label="Delete all closed paper positions">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M3 6h18" />
                                            <path d="M8 6V4h8v2" />
                                            <path d="M19 6l-1 14H6L5 6" />
                                            <path d="M10 11v6" />
                                            <path d="M14 11v6" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="rolling-demo-table-wrap">
                    <table class="rolling-demo-table rolling-demo-table-closed">
                        <thead>
                            <tr>
                                <th>Delta</th>
                                <th>C Delta</th>
                                <th>Start DT</th>
                                <th>End DT</th>
                                <th>Symbol</th>
                                <th>Tr Type</th>
                                <th>Lot Sz</th>
                                <th>Qty</th>
                                <th>Buy Price</th>
                                <th>Sell Price</th>
                                <th>Charges</th>
                                <th>P &amp; L</th>
                                <th>Comment</th>
                            </tr>
                        </thead>
                        <tbody id="rollingDemoClosedPositionsBody">
                            <tr>
                                <td colspan="13" class="rolling-demo-empty">No closed paper positions yet. This section is ready for server-side history data.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="rolling-demo-section">
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <div class="rolling-demo-inline">
                        <h2>Delta Renko-Style Feed</h2>
                        <label class="rolling-demo-switch">
                            <input type="checkbox" checked />
                            <span>Delta Renko Feed</span>
                        </label>
                        <span class="rolling-demo-badge secondary">OFF</span>
                        <button class="rolling-demo-signal idle" type="button" id="rollingDemoLastSignal" title="Click to toggle manual Renko signal">
                            -
                        </button>
                        <span class="rolling-demo-badge secondary" id="rollingDemoTradingViewEmaTrend">TV EMA: FLAT</span>
                    </div>
                    <div class="rolling-demo-card-tools">
                        <div class="rolling-demo-field">
                            <label for="txtRenkoFeedPts">Point</label>
                            <input type="number" id="txtRenkoFeedPts" value="10" min="1" />
                        </div>
                        <div class="rolling-demo-field">
                            <label for="ddlRenkoFeedPriceSrc">Source</label>
                            <select id="ddlRenkoFeedPriceSrc">
                                <option value="mark_price">Mark Price</option>
                                <option value="spot_price" selected>Spot Price</option>
                                <option value="best_bid">Best Bid</option>
                                <option value="best_ask">Best Ask</option>
                            </select>
                        </div>
                        <div class="rolling-demo-field">
                            <label for="chkRollingDemoTradingViewEma">TV EMA</label>
                            <label class="rolling-demo-check">
                                <input type="checkbox" id="chkRollingDemoTradingViewEma" />
                                <span>ON</span>
                            </label>
                        </div>
                        <div class="rolling-demo-field">
                            <label for="ddlRollingDemoTradingViewEmaSide">Side</label>
                            <select id="ddlRollingDemoTradingViewEmaSide">
                                <option value="both" selected>Both</option>
                                <option value="up">UP</option>
                                <option value="down">DOWN</option>
                            </select>
                        </div>
                    </div>
                </div>
                <p class="app-copy rolling-demo-feed-meta">Symbol: BTCUSD | Renko state is driven from the server cycle using the selected price source and point size.</p>
                <div class="rolling-demo-rule-messages" id="rollingDemoRuleSettingsMessages" aria-live="polite">
                    <div class="rolling-demo-rule-message-title">Action rule settings confirmations</div>
                    <div class="rolling-demo-rule-message-empty">Action 1 and Action 2 rule updates will appear here without being saved to the activity log.</div>
                </div>
                <div class="rolling-demo-feed">
                    <div class="rolling-demo-feed-item">Enable the feed to let the server evaluate Renko transitions from public Delta market data.</div>
                    <div class="rolling-demo-feed-item">Spot Price, Mark Price, Best Bid, and Best Ask now flow through the Renko engine according to the selected source.</div>
                </div>
            </div>
        </section>

        <section class="rolling-demo-section">
            <div class="rolling-demo-log-grid">
                <div class="app-panel rolling-demo-card">
                    <div class="rolling-demo-card-head">
                        <h2>Telegram Alerts</h2>
                    </div>
                    <p class="app-copy">Choose which server events should also be sent to your Telegram chat. These preferences are saved per user for this strategy.</p>
                    <div class="rolling-demo-notice">
                        <% if (currentAccount?.telegramChatId) { %>
                            Telegram Chat ID configured: <strong><%= currentAccount.telegramChatId %></strong>
                        <% } else { %>
                            Telegram Chat ID is not set on your profile yet. Add it in <a href="/account/profile">My Profile</a> to receive alerts.
                        <% } %>
                    </div>
                    <div class="rolling-demo-check-panel">
                        <label class="rolling-demo-check rolling-demo-check-wide" for="chkRollingDemoTelegramAlertsEnabled">
                            <input type="checkbox" id="chkRollingDemoTelegramAlertsEnabled" />
                            <span>Enable Telegram alerts for Rolling Options - Strangle</span>
                        </label>
                    </div>
                    <div class="rolling-demo-event-prefs">
                        <% for (const eventType of rollingTelegramEventTypes || []) { %>
                            <label class="rolling-demo-check rolling-demo-check-wide" for="pref-<%= eventType %>">
                                <input type="checkbox" class="rolling-demo-telegram-event" id="pref-<%= eventType %>" value="<%= eventType %>" />
                                <span><%= eventType.replaceAll('_', ' ') %></span>
                            </label>
                        <% } %>
                    </div>
                </div>

                <div class="app-panel rolling-demo-card">
                    <div class="rolling-demo-card-head">
                        <h2>Activity Log</h2>
                        <div class="rolling-demo-card-tools">
                            <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingDemoClearEvents" title="Delete all activity log messages for this user" aria-label="Delete all activity log messages for this user">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 6h18" />
                                    <path d="M8 6V4h8v2" />
                                    <path d="M19 6l-1 14H6L5 6" />
                                    <path d="M10 11v6" />
                                    <path d="M14 11v6" />
                                </svg>
                            </button>
                            <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingDemoRefreshEvents" title="Refresh activity log" aria-label="Refresh activity log">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                                    <path d="M21 3v6h-6" />
                                </svg>
                            </button>
                        </div>
                    </div>
                    <p class="app-copy">Recent server-side actions are shown here. The app keeps only the latest 500 messages per user for this strategy and automatically prunes messages older than 10 days.</p>
                    <div class="rolling-demo-event-log" id="rollingDemoEventLog">
                        <div class="rolling-demo-event-empty">No server activity has been logged yet.</div>
                    </div>
                    <label class="rolling-demo-check rolling-demo-check-wide" for="chkRollingDemoHideRenkoEvents" title="Hide Renko Change Detected messages in the activity log">
                        <input type="checkbox" id="chkRollingDemoHideRenkoEvents" />
                        <span>Hide Renko Changes</span>
                    </label>
                    <label class="rolling-demo-check rolling-demo-check-wide" for="chkRollingDemoHideRenkoGreenSkippedEvents" title="Hide Renko GREEN Skipped and Renko RED Skipped messages in the activity log">
                        <input type="checkbox" id="chkRollingDemoHideRenkoGreenSkippedEvents" />
                        <span>Hide Renko Skipped</span>
                    </label>
                </div>
            </div>
        </section>
    </div>
    <script src="/js/open-position-payoff-graph.js"></script>
    <script src="/js/rolling-options-strangle-shared.js"></script>
    <script src="/js/rolling-options-strangle.js?v=20260614-profile-sync-2"></script>
</body>
</html>
