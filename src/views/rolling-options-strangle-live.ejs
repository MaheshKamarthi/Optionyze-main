        <div class="rolling-strangle-live-status" id="rollingStrangleLiveImportStatus"></div>
        <div class="rolling-strangle-live-import-list" id="rollingStrangleLiveImportList">
            <div class="rolling-demo-event-empty">Select an API profile to load open live positions.</div>
        </div>
        <div class="rolling-strangle-live-modal-actions">
            <button class="rolling-demo-btn primary" type="button" id="btnRollingStrangleLiveApplyImportedPositions">Import Selected</button>
        </div>
    </section>

